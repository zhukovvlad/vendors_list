# ============================================================================
#  Vendors — пример окружения. Скопируйте в .env и заполните.
#  Файл .env в git НЕ коммитится (см. .gitignore).
# ============================================================================

# --- База данных (PostgreSQL 18; dev — Neon) -------------------------------
# ОДНА строка — async-URL приложения (драйвер asyncpg). Sync-URL для Alembic
# выводится из неё автоматически (asyncpg -> psycopg, ssl=require -> sslmode=require).
# База одна; отличается только «разъём».
DATABASE_URL=postgresql+asyncpg://vendors:vendors@localhost:5432/vendors
#
# Пример для Neon (пулированный хост + SSL для asyncpg):
# DATABASE_URL=postgresql+asyncpg://neondb_owner:<PASSWORD>@ep-...-pooler.us-east-1.aws.neon.tech/neondb?ssl=require
#
# Тестовая ветка Neon (data+schema копия production). Пусто — db-тесты скипаются.
# Хвост ssl=require обязателен (драйвер asyncpg), НЕ sslmode/channel_binding.
DATABASE_URL_TEST=

# --- Приложение -------------------------------------------------------------
APP_ENV=dev                     # dev | prod
LOG_LEVEL=INFO
# CORS: список origin фронтенда через запятую
CORS_ORIGINS=http://localhost:5173

# --- SSO / OIDC (Entra ID или Keycloak) ------------------------------------
# Свою аутентификацию не пишем — только OIDC.
OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_AUDIENCE=<api-client-id>
OIDC_CLIENT_ID=<api-client-id>
OIDC_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
# Claim, из которого берём роль (viewer | admin) и логин для аудита:
OIDC_ROLES_CLAIM=roles
OIDC_USERNAME_CLAIM=preferred_username

# В dev можно отключить проверку токена и работать под фиктивным пользователем.
# В prod ОБЯЗАТЕЛЬНО false.
AUTH_DEV_BYPASS=true
AUTH_DEV_USER=dev@local
AUTH_DEV_ROLE=admin
